{
  "name": "@capgo/tauri-updater",
  "version": "0.0.1",
  "description": "OTA updates for Tauri applications - 100% feature parity with capacitor-updater",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "tauri",
    "updater",
    "ota",
    "live-update",
    "capgo",
    "hot-reload"
  ],
  "author": "Martin Donadieu <martin@capgo.app>",
  "license": "MPL-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Cap-go/tauri-updater.git"
  },
  "bugs": {
    "url": "https://github.com/Cap-go/tauri-updater/issues"
  },
  "homepage": "https://capgo.app/docs/",
  "peerDependencies": {
    "@tauri-apps/api": ">=2.0.0",
    "@tauri-apps/plugin-fs": ">=2.0.0",
    "@tauri-apps/plugin-http": ">=2.0.0",
    "@tauri-apps/plugin-process": ">=2.0.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.48.1",
    "@typescript-eslint/parser": "^8.48.1",
    "eslint": "^8.55.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "dependencies": {
    "brotli-wasm": "^3.0.0",
    "fflate": "^0.8.2",
    "node-forge": "^1.3.1"
  }
}
